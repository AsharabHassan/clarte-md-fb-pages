# ───────────────────────────────────────────────────────────────────
#  Clarté MD Skincare App — environment variables template
#  Copy to .env.local and fill in the values.
#  NEVER commit .env.local (it is gitignored).
# ───────────────────────────────────────────────────────────────────

# ── Supabase (shared project — Settings → API) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Postgres (Transaction pooler, port 6543) ───────────────────────
# URL-encode any special characters in the password (@ → %40, / → %2F, etc.)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

# ── Google AI (Gemini) — https://aistudio.google.com/apikey ───────
GEMINI_API_KEY=

# ── OpenAI (gpt-image-1 + gpt-4o for skin-map and before/after) ───
OPENAI_API_KEY=

# ── App secrets ────────────────────────────────────────────────────
# 32-byte random hex (generate with: openssl rand -hex 32)
IP_HASH_PEPPER=replace-with-32-byte-random-hex

# ── Analytics ──────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=

# ── Application ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── Automation webhooks ────────────────────────────────────────────
# Each fires a JSON POST when its event happens. Leave blank to skip.
# Lead-capture gate (name/email/phone before results) → lead.captured
WEBHOOK_LEAD_CAPTURED=
WEBHOOK_ORDER_CREATED=
WEBHOOK_ORDER_CONFIRMED=
WEBHOOK_ORDER_DISPATCHED=
WEBHOOK_ORDER_DELIVERED=
WEBHOOK_ORDER_CANCELLED=
WEBHOOK_ORDER_REFUNDED=

# ── Rate limiting (optional, defaults to 10/hr AI, 5/hr orders) ────
AI_RATE_LIMIT_PER_HOUR=100
